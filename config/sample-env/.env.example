# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=License Manager API
VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Keycloak / OIDC
# -----------------------------------------------------------------------------
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=master
# Accepts single value, comma-separated list, or JSON array
KEYCLOAK_VERIFY_SSL=true
KEYCLOAK_CLIENT_ID=license-manager
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_SECRET=
KEYCLOAK_CALLBACK_URI=http://localhost:8000/docs/oauth2-redirect.html

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Accepts single value, comma-separated list, or JSON array
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
LOG_TO_FILE=false
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/app.error.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Azure Key Vault
# -----------------------------------------------------------------------------
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_USE_CLI_CREDENTIAL=false
SMTP_CREDENTIALS_SECRET_NAME=smtp-credentials
APP_PACKAGES_DIR=AppPackages

# -----------------------------------------------------------------------------
# PostgreSQL / SQLAlchemy
# -----------------------------------------------------------------------------
# Preferred: single DSN
POSTGRES_DSN=
# Also respected aliases:
# DATABASE_URL=
# DB_DSN=

# Optional component variables (used when POSTGRES_DSN is not set)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# SQLAlchemy engine options
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_POOL_RECYCLE=216

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_DEFAULT_QUEUE=license_manager

# -----------------------------------------------------------------------------
# License background jobs
# -----------------------------------------------------------------------------
LICENSE_CHECK_CRON=
LICENSE_ARCHIVER_CRON=
# Accepts single value, comma-separated list, or JSON array
LICENSE_CHECK_DAYS_FROM_TODAY_TO_CHECK=30,14,7,1
